# codeforchord/services/audio-processor/.env


CFC_AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=your-azure-storage-account-name;AccountKey=your-azure-storage-account-key;EndpointSuffix=core.windows.net
CFC_AZURE_STORAGE_ACCOUNT_NAME=codeforchord
CFC_AZURE_STORAGE_ACCOUNT_KEY=your-azure-storage-account-key
CFC_MONGODB_URL=mongodb+srv://your-mongodb-username:your-mongodb-password@your-mongodb-url/?appName=your-mongodb-database
CFC_MONGODB_DATABASE=your-mongodb-database
CFC_AUTH0_DOMAIN=your-auth0-domain
CFC_AUTH0_AUDIENCE=https://your-auth0-audience



