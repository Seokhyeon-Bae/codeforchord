# Public (exposed to browser at build time — set in Vercel → Settings → Environment Variables)
VITE_API_URL=https://your-api.example.com

# Production site URL for Auth0 callback + logout (required on Vercel — must match Auth0 app settings exactly)
# Example: https://your-app.vercel.app  (no trailing slash)
VITE_APP_ORIGIN=

# Auth0 (optional — leave empty to skip login UI issues during dev)
VITE_AUTH0_DOMAIN=
VITE_AUTH0_CLIENT_ID=
VITE_AUTH0_AUDIENCE=
